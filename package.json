{
  "name": "fundamentals-project-ts-template",
  "version": "1.0.0",
  "description": "Capstone Project TS Template",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "predev": "rm -rf dist",
    "dev": "concurrently \"npx sass src/scss/main.scss dist/css/main.css --watch\" \"tsc --watch\" \"live-server . --open=src/index.html --port=3000\"",
    "build": "npx sass src/scss/main.scss dist/css/main.css && npx tsc",
    "ts-compile": "npx tsc",
    "lint:ts": "eslint \"src/**/*.ts\"",
    "lint:scss": "stylelint \"src/**/*.scss\" --fix",
    "lint": "npm run lint:ts && npm run lint:scss"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "live-server": "^1.2.2",
    "stylelint": "^17.9.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.1"
  }
}
